.vscode/
.cursor/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*~
.DS_Store

# ==========================================
# 4. 安全红线：敏感信息与密钥文件（⚠️ 极其重要）
# ==========================================
# 存放 API 密钥（如 DeepSeek_API_KEY、Database_PASSWORD）的文件绝对不能公开！
.env
.env.local
.env.*
*.env
credentials.json
*.pem
*.key

# ==========================================
# 5. AI/RAG 专属：本地模型与大型数据集过滤
# ==========================================
# 防止你不小心把本地下载的几十G的 FlagEmbedding / BGE 权重文件传上去
models/
.models/
huggingface/
.cache/huggingface/
.cache/torch/
datasets/
*.bin
*.pt
*.pth
*.onnx
*.safetensors

# ==========================================
# 6. Docker 与本地数据库持久化数据
# ==========================================
# 刚才在 Mac 上通过绝对路径挂载映射出来的本地数据，千万别进 Git
data/
db/
*.db
*.sqlite3
.qdrant/
postgres_data/

