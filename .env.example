APP_NAME=Enterprise AI Platform
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=0.1.0

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=enterprise_ai_platform

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=enterprise_ai
REDIS_SESSION_TTL_SECONDS=86400
REDIS_TOOL_CACHE_TTL_SECONDS=3600
REDIS_CHECKPOINT_TTL_SECONDS=86400

QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333

LLM_PROVIDER=dashscope
LLM_MODEL=qwen-turbo
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=30

LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_STREAM=false

#LLM_PROVIDER=dummy
#LLM_MODEL=dummy-llm
#LLM_TEMPERATURE=0.2
#LLM_MAX_TOKENS=
#LLM_TIMEOUT=30
#LLM_BASE_URL=
#LLM_API_KEY=
#LLM_STREAM=false

# OpenAI example:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-5.5
# LLM_API_KEY=your_openai_api_key
# LLM_BASE_URL=
# LLM_TIMEOUT=30
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=1024
# LLM_STREAM=false

EMBEDDING_MODEL_PATH=
RERANKER_MODEL_PATH=

EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_DIMENSION=1024

RERANK_PROVIDER=dummy
RERANK_MODEL=gte-rerank-v2
RERANK_API_KEY=
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RERANK_TOP_K=20
RERANK_TIMEOUT=30
RERANK_FAIL_OPEN=true

CONTEXT_COMPRESSION_ENABLED=true
CONTEXT_COMPRESSION_PROVIDER=rule_based
CONTEXT_COMPRESSION_MAX_CHARS=6000
CONTEXT_COMPRESSION_MAX_CHUNK_CHARS=1200
CONTEXT_COMPRESSION_FAIL_OPEN=true
CONTEXT_COMPRESSION_LLM_MODEL=qwen-turbo
CONTEXT_COMPRESSION_LLM_TEMPERATURE=0
CONTEXT_COMPRESSION_LLM_MAX_CHARS_PER_CHUNK=1200
CONTEXT_COMPRESSION_LLM_TIMEOUT_SECONDS=30
CONTEXT_COMPRESSION_LLM_MAX_CALLS=8

NEIGHBOR_EXPANSION_ENABLED=true
NEIGHBOR_EXPANSION_BEFORE=1
NEIGHBOR_EXPANSION_AFTER=1
NEIGHBOR_EXPANSION_MAX_ADDED_CHUNKS=10
NEIGHBOR_EXPANSION_FAIL_OPEN=true

MMR_ENABLED=true
MMR_LAMBDA=0.7
MMR_TOP_K=5
MMR_MIN_SCORE=0.0
MMR_FAIL_OPEN=true
MMR_SIMILARITY_THRESHOLD=0.85

EVALUATION_KEYWORD_THRESHOLD=0.5
EVALUATION_V2_ENABLED=true
EVALUATION_REPORT_DIR=evaluation/reports
EVALUATION_HISTORY_ENABLED=true
EVALUATION_BASELINE_ENABLED=true
EVALUATION_MAX_CONCURRENCY=4
EVALUATION_DEFAULT_TIMEOUT_SECONDS=120
EVALUATION_FAIL_FAST=false
EVALUATION_LLM_JUDGE_ENABLED=false
EVALUATION_LLM_JUDGE_MODEL=qwen-turbo
EVALUATION_LLM_JUDGE_TIMEOUT_SECONDS=30
EVALUATION_LLM_JUDGE_RETRY_COUNT=1
EVALUATION_COST_CONFIG_PATH=evaluation/v2/costs.yaml
EVALUATION_REPORT_MAX_TEXT_CHARS=1000
EVALUATION_REPORT_REDACT_ENABLED=true

MEMORY_PROVIDER=redis

AGENT_RUNTIME=v1
AGENT_ASYNC_ENABLED=true
AGENT_ASYNC_TIMEOUT_SECONDS=60
AGENT_TOOL_TIMEOUT_SECONDS=30
AGENT_TOOL_MAX_CONCURRENCY=4
AGENT_TOOL_RETRY_COUNT=1
AGENT_ASYNC_FAIL_OPEN=true
AGENT_SYNC_FALLBACK_ENABLED=true
AGENT_LOOP_ENABLED=true
AGENT_PLANNER_STRATEGY=native_tool_calling
AGENT_PLANNER_FALLBACK_ENABLED=true
AGENT_REFLECTION_ENABLED=true
AGENT_REFLECTION_AFTER_TOOL_FAILURE=true
AGENT_REFLECTION_REPEAT_THRESHOLD=2
AGENT_REFLECTION_MAX_COUNT=2
AGENT_MAX_STEPS=12
AGENT_MAX_LLM_CALLS=8
AGENT_MAX_TOOL_CALLS=10
AGENT_MAX_REFLECTIONS=2
AGENT_MAX_SAME_TOOL_REPEATS=2
AGENT_MAX_DURATION_SECONDS=120
AGENT_OBSERVATION_MAX_CHARS=6000
AGENT_MEMORY_MAX_LOOP_MESSAGES=20

DYNAMIC_TOOL_REGISTRY_ENABLED=true
TOOL_REGISTRY_AUTO_REFRESH=false
TOOL_REGISTRY_REFRESH_INTERVAL_SECONDS=300
TOOL_REGISTRY_FAIL_OPEN=true

TOOL_PLUGIN_ENABLED=true
TOOL_PLUGIN_PATH=backend/app/tools/plugins

HTTP_TOOL_PROVIDER_ENABLED=false
HTTP_TOOL_CONFIG_PATH=config/tools/http_tools.json
HTTP_TOOL_DEFAULT_TIMEOUT_SECONDS=30

WORKFLOW_TOOL_PROVIDER_ENABLED=true
MCP_TOOL_PROVIDER_ENABLED=false

MCP_ENABLED=false
MCP_CONFIG_PATH=config/mcp/servers.json
MCP_DISCOVERY_ON_STARTUP=true
MCP_FAIL_OPEN=true
MCP_DEFAULT_CONNECT_TIMEOUT_SECONDS=10
MCP_DEFAULT_TOOL_TIMEOUT_SECONDS=30
MCP_DEFAULT_RETRY_COUNT=1
MCP_MAX_CONCURRENCY=4
MCP_STDIO_ENABLED=true
MCP_STREAMABLE_HTTP_ENABLED=true
MCP_SSE_COMPAT_ENABLED=false
MCP_AUTO_RECONNECT=true
MCP_HEALTH_CHECK_ENABLED=true
MCP_HEALTH_CHECK_INTERVAL_SECONDS=60
MCP_AUDIT_ENABLED=true
MCP_ALLOW_INSECURE_HTTP_LOCALHOST=true
MCP_STDIO_ALLOWED_COMMANDS=python,python3,python3.12,node,npx,uv,uvx
MCP_PERMISSION_ENFORCEMENT_ENABLED=false
MCP_PERMISSION_FAIL_OPEN=false

WORKFLOW_RUNTIME=v1
WORKFLOW_V2_ENABLED=true
WORKFLOW_DEFAULT_TIMEOUT_SECONDS=120
WORKFLOW_MAX_STEPS_DEFAULT=20
WORKFLOW_MAX_CONCURRENCY=4
WORKFLOW_PARALLEL_FAIL_FAST=false
WORKFLOW_CHECKPOINT_ENABLED=true
WORKFLOW_CHECKPOINT_PROVIDER=redis
WORKFLOW_CHECKPOINT_FAIL_OPEN=true
WORKFLOW_CHECKPOINT_TTL_SECONDS=86400
WORKFLOW_APPROVAL_ENABLED=true
WORKFLOW_APPROVAL_PERMISSION_ENFORCEMENT=false
WORKFLOW_APPROVAL_FAIL_OPEN=false
WORKFLOW_APPROVAL_DEFAULT_TIMEOUT_SECONDS=86400
WORKFLOW_STREAMING_ENABLED=true
WORKFLOW_FAIL_OPEN_TO_V1=true

UPLOAD_DIR=./data/uploads
