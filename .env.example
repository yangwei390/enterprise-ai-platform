# 应用名称，用于日志和服务标识。
APP_NAME=Enterprise AI Platform
# 应用运行环境，开发环境使用 dev。
APP_ENV=dev
# API 服务监听地址，0.0.0.0 表示允许局域网访问。
APP_HOST=0.0.0.0
# API 服务监听端口。
APP_PORT=8000
# 应用版本号。
APP_VERSION=0.1.0

# PostgreSQL 主机地址。
POSTGRES_HOST=127.0.0.1
# PostgreSQL 端口。
POSTGRES_PORT=5432
# PostgreSQL 用户名。
POSTGRES_USER=postgres
# PostgreSQL 密码，真实环境请在 .env 中配置。
POSTGRES_PASSWORD=postgres
# PostgreSQL 数据库名称。
POSTGRES_DB=enterprise_ai_platform

# Redis 主机地址。
REDIS_HOST=127.0.0.1
# Redis 端口。
REDIS_PORT=6379
# Redis 密码，未设置密码时留空。
REDIS_PASSWORD=
# 是否启用 Redis。
REDIS_ENABLED=true
# Redis 连接 URL。
REDIS_URL=redis://localhost:6379/0
# Redis Key 前缀，用于隔离项目数据。
REDIS_PREFIX=enterprise_ai
# Redis 会话数据过期时间，单位秒。
REDIS_SESSION_TTL_SECONDS=86400
# Redis 工具缓存过期时间，单位秒。
REDIS_TOOL_CACHE_TTL_SECONDS=3600
# Redis Checkpoint 过期时间，单位秒。
REDIS_CHECKPOINT_TTL_SECONDS=86400

# Qdrant 主机地址。
QDRANT_HOST=127.0.0.1
# Qdrant 端口。
QDRANT_PORT=6333

# 默认 LLM Provider。
LLM_PROVIDER=dashscope
# 默认 LLM 模型名称。
LLM_MODEL=qwen-turbo
# 默认 LLM 温度参数。
LLM_TEMPERATURE=0.2
# 默认 LLM 最大输出 Token 数。
LLM_MAX_TOKENS=1024
# 默认 LLM 请求超时时间，单位秒。
LLM_TIMEOUT=30

# LLM 兼容 OpenAI 协议的 Base URL。
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM API Key，真实密钥只允许写入 .env。
LLM_API_KEY=
# 是否启用 LLM 流式输出。
LLM_STREAM=false

# Dummy LLM 示例：启用时取消下方注释。
#LLM_PROVIDER=dummy
# Dummy LLM 模型名。
#LLM_MODEL=dummy-llm
# Dummy LLM 温度参数。
#LLM_TEMPERATURE=0.2
# Dummy LLM 最大输出 Token，留空表示使用默认值。
#LLM_MAX_TOKENS=
# Dummy LLM 超时时间，单位秒。
#LLM_TIMEOUT=30
# Dummy LLM Base URL，通常留空。
#LLM_BASE_URL=
# Dummy LLM API Key，通常留空。
#LLM_API_KEY=
# Dummy LLM 是否启用流式输出。
#LLM_STREAM=false

# OpenAI 示例：启用时取消下方注释。
# OpenAI Provider 名称。
# LLM_PROVIDER=openai
# OpenAI 模型名称。
# LLM_MODEL=gpt-5.5
# OpenAI API Key，真实密钥只允许写入 .env。
# LLM_API_KEY=your_openai_api_key
# OpenAI Base URL，默认官方地址时可留空。
# LLM_BASE_URL=
# OpenAI 请求超时时间，单位秒。
# LLM_TIMEOUT=30
# OpenAI 温度参数。
# LLM_TEMPERATURE=0.2
# OpenAI 最大输出 Token 数。
# LLM_MAX_TOKENS=1024
# OpenAI 是否启用流式输出。
# LLM_STREAM=false

# 本地 Embedding 模型路径，使用远程 Provider 时可留空。
EMBEDDING_MODEL_PATH=
# 本地 Reranker 模型路径，使用远程 Provider 时可留空。
RERANKER_MODEL_PATH=

# Embedding Provider。
EMBEDDING_PROVIDER=dashscope
# Embedding 模型名称。
EMBEDDING_MODEL=text-embedding-v3
# Embedding API Key，真实密钥只允许写入 .env。
EMBEDDING_API_KEY=
# Embedding Base URL。
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Embedding 向量维度。
EMBEDDING_DIMENSION=1024
# Embedding 批处理大小。
EMBEDDING_BATCH_SIZE=10

# Chunk 策略，auto 表示自动路由。
CHUNK_STRATEGY=auto
# 是否启用文档类型识别。
DOCUMENT_CLASSIFICATION_ENABLED=true
# 是否启用文档结构解析。
DOCUMENT_STRUCTURE_ENABLED=true
# 结构解析失败时是否降级继续。
DOCUMENT_STRUCTURE_FAIL_OPEN=true
# 文档结构最大节点数。
DOCUMENT_STRUCTURE_MAX_NODES=10000
# 文档结构最大深度。
DOCUMENT_STRUCTURE_MAX_DEPTH=20
# 递归 Chunk 最大字符数。
CHUNK_RECURSIVE_SIZE=1000
# 递归 Chunk 重叠字符数。
CHUNK_RECURSIVE_OVERLAP=150
# Chunk 最小字符数。
CHUNK_MIN_CHARS=100
# 法律类 Chunk 最大字符数。
CHUNK_LEGAL_MAX_CHARS=1500
# 法律类短条款是否合并分组。
CHUNK_LEGAL_GROUP_SHORT_ARTICLES=true
# 法律类短条款分组最小字符数。
CHUNK_LEGAL_MIN_GROUP_CHARS=400
# Markdown Chunk 最大字符数。
CHUNK_MARKDOWN_MAX_CHARS=1500
# 是否启用语义 Chunk。
CHUNK_SEMANTIC_ENABLED=false
# 语义 Chunk 相似度阈值。
CHUNK_SEMANTIC_SIMILARITY_THRESHOLD=0.55
# 语义 Chunk 最大段落数。
CHUNK_SEMANTIC_MAX_PARAGRAPHS=200
# 语义 Chunk 批处理大小。
CHUNK_SEMANTIC_BATCH_SIZE=32
# 是否启用 Parent/Child Chunk。
CHUNK_PARENT_CHILD_ENABLED=true
# Parent Chunk 最大字符数。
CHUNK_PARENT_MAX_CHARS=6000
# Child Chunk 最大字符数。
CHUNK_CHILD_MAX_CHARS=1000
# 是否对 Parent Chunk 生成 Embedding。
CHUNK_EMBED_PARENT=false
# 是否启用结构化查询提示。
STRUCTURE_QUERY_HINT_ENABLED=true
# 结构命中软增强系数。
STRUCTURE_SOFT_BOOST_FACTOR=1.3
# 是否启用 Retrieval Planner。
RETRIEVAL_PLANNER_ENABLED=true
# Retrieval Planner 是否调用 LLM。
RETRIEVAL_PLANNER_LLM_ENABLED=false
# Retrieval Planner 超时时间，单位毫秒。
RETRIEVAL_PLANNER_TIMEOUT_MS=100
# Retrieval Planner 失败时是否降级继续。
RETRIEVAL_PLANNER_FAIL_OPEN=true
# 默认检索策略。
RETRIEVAL_DEFAULT_STRATEGY=hybrid
# 结构化查询检索策略。
RETRIEVAL_STRUCTURED_STRATEGY=structured_hybrid
# Dense 检索权重。
RETRIEVAL_DENSE_WEIGHT=0.5
# Sparse 检索权重。
RETRIEVAL_SPARSE_WEIGHT=0.5
# Dense-heavy 策略中的 Dense 权重。
RETRIEVAL_DENSE_HEAVY_WEIGHT=0.7
# Sparse-heavy 策略中的 Sparse 权重。
RETRIEVAL_SPARSE_HEAVY_WEIGHT=0.7

# Rerank Provider。
RERANK_PROVIDER=dummy
# Rerank 模型名称。
RERANK_MODEL=gte-rerank-v2
# Rerank API Key，真实密钥只允许写入 .env。
RERANK_API_KEY=
# Rerank Base URL。
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Rerank 输入 TopK。
RERANK_TOP_K=20
# Rerank 超时时间，单位秒。
RERANK_TIMEOUT=30
# Rerank 失败时是否降级继续。
RERANK_FAIL_OPEN=true

# 是否启用上下文压缩。
CONTEXT_COMPRESSION_ENABLED=true
# 上下文压缩 Provider。
CONTEXT_COMPRESSION_PROVIDER=rule_based
# 压缩后上下文最大字符数。
CONTEXT_COMPRESSION_MAX_CHARS=6000
# 单个 Chunk 压缩最大字符数。
CONTEXT_COMPRESSION_MAX_CHUNK_CHARS=1200
# 上下文压缩失败时是否降级继续。
CONTEXT_COMPRESSION_FAIL_OPEN=true
# LLM 压缩使用的模型。
CONTEXT_COMPRESSION_LLM_MODEL=qwen-turbo
# LLM 压缩温度参数。
CONTEXT_COMPRESSION_LLM_TEMPERATURE=0
# LLM 压缩单 Chunk 最大字符数。
CONTEXT_COMPRESSION_LLM_MAX_CHARS_PER_CHUNK=1200
# LLM 压缩超时时间，单位秒。
CONTEXT_COMPRESSION_LLM_TIMEOUT_SECONDS=30
# LLM 压缩最大调用次数。
CONTEXT_COMPRESSION_LLM_MAX_CALLS=8

# 是否启用邻近 Chunk 扩展。
NEIGHBOR_EXPANSION_ENABLED=true
# 向前扩展的 Chunk 数量。
NEIGHBOR_EXPANSION_BEFORE=1
# 向后扩展的 Chunk 数量。
NEIGHBOR_EXPANSION_AFTER=1
# 邻近扩展最多新增 Chunk 数。
NEIGHBOR_EXPANSION_MAX_ADDED_CHUNKS=10
# 邻近扩展失败时是否降级继续。
NEIGHBOR_EXPANSION_FAIL_OPEN=true

# 是否启用 MMR 去冗余。
MMR_ENABLED=true
# MMR 相关性与多样性平衡系数。
MMR_LAMBDA=0.7
# MMR 输出 TopK。
MMR_TOP_K=5
# MMR 最小分数阈值。
MMR_MIN_SCORE=0.0
# MMR 失败时是否降级继续。
MMR_FAIL_OPEN=true
# MMR 相似度去重阈值。
MMR_SIMILARITY_THRESHOLD=0.85

# Evaluation 关键词命中阈值。
EVALUATION_KEYWORD_THRESHOLD=0.5
# 是否启用 Evaluation V2。
EVALUATION_V2_ENABLED=true
# Evaluation 报告目录。
EVALUATION_REPORT_DIR=evaluation/reports
# 是否保存 Evaluation 历史记录。
EVALUATION_HISTORY_ENABLED=true
# 是否启用 Evaluation baseline。
EVALUATION_BASELINE_ENABLED=true
# Evaluation 最大并发数。
EVALUATION_MAX_CONCURRENCY=4
# Evaluation 默认超时时间，单位秒。
EVALUATION_DEFAULT_TIMEOUT_SECONDS=120
# Evaluation 失败时是否立即停止。
EVALUATION_FAIL_FAST=false
# 是否启用 LLM Judge。
EVALUATION_LLM_JUDGE_ENABLED=false
# LLM Judge 模型名称。
EVALUATION_LLM_JUDGE_MODEL=qwen-turbo
# LLM Judge 超时时间，单位秒。
EVALUATION_LLM_JUDGE_TIMEOUT_SECONDS=30
# LLM Judge 重试次数。
EVALUATION_LLM_JUDGE_RETRY_COUNT=1
# Evaluation 成本配置路径。
EVALUATION_COST_CONFIG_PATH=evaluation/v2/costs.yaml
# Evaluation 报告最大文本字符数。
EVALUATION_REPORT_MAX_TEXT_CHARS=1000
# Evaluation 报告是否脱敏。
EVALUATION_REPORT_REDACT_ENABLED=true

# Memory Provider。
MEMORY_PROVIDER=redis

# Agent Runtime 配置；当前正式链路由代码收口到 LangGraph V2。
AGENT_RUNTIME=v1
# 是否启用 Agent 异步运行。
AGENT_ASYNC_ENABLED=true
# Agent 异步运行超时时间，单位秒。
AGENT_ASYNC_TIMEOUT_SECONDS=60
# 单个 Agent Tool 超时时间，单位秒。
AGENT_TOOL_TIMEOUT_SECONDS=30
# Agent Tool 最大并发数。
AGENT_TOOL_MAX_CONCURRENCY=4
# Agent Tool 重试次数。
AGENT_TOOL_RETRY_COUNT=1
# Agent 异步失败时是否降级继续。
AGENT_ASYNC_FAIL_OPEN=true
# Agent Tool 是否允许同步 fallback。
AGENT_SYNC_FALLBACK_ENABLED=true
# 是否启用 Agent Loop。
AGENT_LOOP_ENABLED=true
# Agent Planner 策略。
AGENT_PLANNER_STRATEGY=native_tool_calling
# Agent Planner 失败时是否启用 fallback。
AGENT_PLANNER_FALLBACK_ENABLED=true
# 是否启用 Agent Reflection。
AGENT_REFLECTION_ENABLED=true
# Tool 失败后是否触发 Reflection。
AGENT_REFLECTION_AFTER_TOOL_FAILURE=true
# 触发重复 Reflection 的阈值。
AGENT_REFLECTION_REPEAT_THRESHOLD=2
# Agent Reflection 最大次数。
AGENT_REFLECTION_MAX_COUNT=2
# Agent 最大执行步数。
AGENT_MAX_STEPS=12
# Agent 最大 LLM 调用次数。
AGENT_MAX_LLM_CALLS=8
# Agent 最大 Tool 调用次数。
AGENT_MAX_TOOL_CALLS=10
# Agent 最大 Reflection 次数。
AGENT_MAX_REFLECTIONS=2
# Agent 同一工具最大连续重复次数。
AGENT_MAX_SAME_TOOL_REPEATS=2
# Agent 最大运行时长，单位秒。
AGENT_MAX_DURATION_SECONDS=120
# Agent Observation 最大字符数。
AGENT_OBSERVATION_MAX_CHARS=6000
# Agent Memory 注入循环消息上限。
AGENT_MEMORY_MAX_LOOP_MESSAGES=20

# 是否启用动态工具注册表。
DYNAMIC_TOOL_REGISTRY_ENABLED=true
# 是否自动刷新工具注册表。
TOOL_REGISTRY_AUTO_REFRESH=false
# 工具注册表刷新间隔，单位秒。
TOOL_REGISTRY_REFRESH_INTERVAL_SECONDS=300
# 工具注册表失败时是否降级继续。
TOOL_REGISTRY_FAIL_OPEN=true

# 是否启用插件工具。
TOOL_PLUGIN_ENABLED=true
# 插件工具目录。
TOOL_PLUGIN_PATH=backend/app/tools/plugins

# 是否启用 HTTP Tool Provider。
HTTP_TOOL_PROVIDER_ENABLED=false
# HTTP Tool 配置文件路径。
HTTP_TOOL_CONFIG_PATH=config/tools/http_tools.json
# HTTP Tool 默认超时时间，单位秒。
HTTP_TOOL_DEFAULT_TIMEOUT_SECONDS=30

# 是否启用 Workflow Tool Provider。
WORKFLOW_TOOL_PROVIDER_ENABLED=true
# 是否启用 MCP Tool Provider。
MCP_TOOL_PROVIDER_ENABLED=false

# 是否启用 MCP。
MCP_ENABLED=false
# MCP 服务配置文件路径。
MCP_CONFIG_PATH=config/mcp/servers.json
# 是否在启动时发现 MCP 工具。
MCP_DISCOVERY_ON_STARTUP=true
# MCP 失败时是否降级继续。
MCP_FAIL_OPEN=true
# MCP 默认连接超时时间，单位秒。
MCP_DEFAULT_CONNECT_TIMEOUT_SECONDS=10
# MCP 默认工具调用超时时间，单位秒。
MCP_DEFAULT_TOOL_TIMEOUT_SECONDS=30
# MCP 默认重试次数。
MCP_DEFAULT_RETRY_COUNT=1
# MCP 最大并发数。
MCP_MAX_CONCURRENCY=4
# 是否启用 MCP stdio 传输。
MCP_STDIO_ENABLED=true
# 是否启用 MCP streamable-http 传输。
MCP_STREAMABLE_HTTP_ENABLED=true
# 是否启用 MCP SSE 兼容传输。
MCP_SSE_COMPAT_ENABLED=false
# MCP 是否自动重连。
MCP_AUTO_RECONNECT=true
# 是否启用 MCP 健康检查。
MCP_HEALTH_CHECK_ENABLED=true
# MCP 健康检查间隔，单位秒。
MCP_HEALTH_CHECK_INTERVAL_SECONDS=60
# 是否启用 MCP 审计。
MCP_AUDIT_ENABLED=true
# 是否允许 localhost 使用非安全 HTTP。
MCP_ALLOW_INSECURE_HTTP_LOCALHOST=true
# MCP stdio 允许执行的命令白名单。
MCP_STDIO_ALLOWED_COMMANDS=python,python3,python3.12,node,npx,uv,uvx
# 是否启用 MCP 权限强制校验。
MCP_PERMISSION_ENFORCEMENT_ENABLED=false
# MCP 权限校验失败时是否放行。
MCP_PERMISSION_FAIL_OPEN=false

# Workflow Runtime 配置；当前正式链路由代码收口到 LangGraph V2。
WORKFLOW_RUNTIME=v1
# 是否启用 Workflow V2。
WORKFLOW_V2_ENABLED=true
# Workflow 默认超时时间，单位秒。
WORKFLOW_DEFAULT_TIMEOUT_SECONDS=120
# Workflow 默认最大步数。
WORKFLOW_MAX_STEPS_DEFAULT=20
# Workflow 最大并发数。
WORKFLOW_MAX_CONCURRENCY=4
# Workflow 并行节点失败时是否立即停止。
WORKFLOW_PARALLEL_FAIL_FAST=false
# 是否启用 Workflow Checkpoint。
WORKFLOW_CHECKPOINT_ENABLED=true
# Workflow Checkpoint Provider。
WORKFLOW_CHECKPOINT_PROVIDER=redis
# Workflow Checkpoint 失败时是否降级继续。
WORKFLOW_CHECKPOINT_FAIL_OPEN=true
# Workflow Checkpoint 过期时间，单位秒。
WORKFLOW_CHECKPOINT_TTL_SECONDS=86400
# 是否启用 Workflow 审批。
WORKFLOW_APPROVAL_ENABLED=true
# 是否强制 Workflow 审批权限校验。
WORKFLOW_APPROVAL_PERMISSION_ENFORCEMENT=false
# Workflow 审批权限校验失败时是否放行。
WORKFLOW_APPROVAL_FAIL_OPEN=false
# Workflow 审批默认超时时间，单位秒。
WORKFLOW_APPROVAL_DEFAULT_TIMEOUT_SECONDS=86400
# 是否启用 Workflow Streaming。
WORKFLOW_STREAMING_ENABLED=true
# Workflow 失败时是否 fallback 到 V1；当前正式链路不应依赖 V1。
WORKFLOW_FAIL_OPEN_TO_V1=true

# 上传文件存储目录。
UPLOAD_DIR=./data/uploads
