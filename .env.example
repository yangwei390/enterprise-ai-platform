APP_NAME=Enterprise AI Platform
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=0.1.0

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=enterprise_ai_platform

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333

LLM_PROVIDER=dashscope
LLM_MODEL=qwen-turbo
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=30

LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_STREAM=false

#LLM_PROVIDER=dummy
#LLM_MODEL=dummy-llm
#LLM_TEMPERATURE=0.2
#LLM_MAX_TOKENS=
#LLM_TIMEOUT=30
#LLM_BASE_URL=
#LLM_API_KEY=
#LLM_STREAM=false

# OpenAI example:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-5.5
# LLM_API_KEY=your_openai_api_key
# LLM_BASE_URL=
# LLM_TIMEOUT=30
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=1024
# LLM_STREAM=false

EMBEDDING_MODEL_PATH=
RERANKER_MODEL_PATH=

EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_DIMENSION=1024

RERANK_PROVIDER=dummy
RERANK_MODEL=gte-rerank-v2
RERANK_API_KEY=
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RERANK_TOP_K=20
RERANK_TIMEOUT=30
RERANK_FAIL_OPEN=true

CONTEXT_COMPRESSION_ENABLED=true
CONTEXT_COMPRESSION_PROVIDER=rule_based
CONTEXT_COMPRESSION_MAX_CHARS=6000
CONTEXT_COMPRESSION_MAX_CHUNK_CHARS=1200
CONTEXT_COMPRESSION_FAIL_OPEN=true
CONTEXT_COMPRESSION_LLM_MODEL=qwen-turbo
CONTEXT_COMPRESSION_LLM_TEMPERATURE=0
CONTEXT_COMPRESSION_LLM_MAX_CHARS_PER_CHUNK=1200
CONTEXT_COMPRESSION_LLM_TIMEOUT_SECONDS=30
CONTEXT_COMPRESSION_LLM_MAX_CALLS=8

NEIGHBOR_EXPANSION_ENABLED=true
NEIGHBOR_EXPANSION_BEFORE=1
NEIGHBOR_EXPANSION_AFTER=1
NEIGHBOR_EXPANSION_MAX_ADDED_CHUNKS=10
NEIGHBOR_EXPANSION_FAIL_OPEN=true

MMR_ENABLED=true
MMR_LAMBDA=0.7
MMR_TOP_K=5
MMR_MIN_SCORE=0.0
MMR_FAIL_OPEN=true
MMR_SIMILARITY_THRESHOLD=0.85

EVALUATION_KEYWORD_THRESHOLD=0.5

AGENT_RUNTIME=v1

UPLOAD_DIR=./data/uploads
